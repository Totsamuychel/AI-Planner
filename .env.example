# --- General ---
ENV=dev
TZ=Europe/Moscow

# --- Postgres ---
POSTGRES_USER=neuroplan
POSTGRES_PASSWORD=neuroplan
POSTGRES_DB=neuroplan
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Compose-side composed URL (used by api + worker)
DATABASE_URL=postgresql+asyncpg://neuroplan:neuroplan@postgres:5432/neuroplan
SYNC_DATABASE_URL=postgresql+psycopg://neuroplan:neuroplan@postgres:5432/neuroplan

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
API_CORS_ORIGINS=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
WEB_PORT=3000

# --- AI (filled in Phase 3) ---
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# --- Ollama (Optional alternative) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Telegram (filled in Phase 5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Google Calendar OAuth ---
# Create an OAuth 2.0 client (Web type) in Google Cloud Console with
# the Calendar API enabled. Add the redirect URI below to "Authorized
# redirect URIs". See docs/GOOGLE_CALENDAR.md for the full walkthrough.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/callback
GOOGLE_POST_AUTH_REDIRECT=http://localhost:3000/settings?google=connected

# --- Obsidian ---
# Path INSIDE the container (do not change).
OBSIDIAN_VAULT_PATH=/data/vault
# Path on the HOST to your real Obsidian vault — bind-mounted read-only.
# Example (Windows): C:\Users\you\Documents\MyVault
# Leave unset to use an in-container placeholder folder.
OBSIDIAN_VAULT_HOST=
